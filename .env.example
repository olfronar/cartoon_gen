# Required
ANTHROPIC_API_KEY=

# Reddit (optional — source skipped if missing)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CartoonMakerBot/0.1 by u/yourusername

# xAI / Grok (optional — X/Twitter trend discovery)
XAI_API_KEY=
# ^ Also used by video_designer for grok-imagine-video generation

# Product Hunt (optional — get from producthunt.com/v2/oauth/applications)
PRODUCT_HUNT_API_KEY=
PRODUCT_HUNT_API_SECRET=

# Bluesky (optional — create app password at bsky.app/settings/app-passwords)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Notion (optional — delivers brief as Notion page)
NOTION_API_KEY=
NOTION_PAGE_ID=

# Slack alerts (optional — success/failure notifications)
SLACK_WEBHOOK_URL=

# Google AI (required for static shots generation)
GOOGLE_API_KEY=

# OpenAI (required for caption maker — Whisper transcription)
OPENAI_API_KEY=
# WHISPER_MODEL=whisper-1

# TikTok Publisher (get from TikTok Developer portal)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
# TIKTOK_PRIVACY_LEVEL=SELF_ONLY
